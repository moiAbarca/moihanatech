---
export const prerender = false;

import DashboardLayout from '../../layouts/DashboardLayout.astro';

// Server-side: fetch leads from the Worker API
const API_BASE = import.meta.env.API_BASE_URL || 'https://api.moihanatech.com';

let leads: any[] = [];
let error = null;

try {
  const res = await fetch(`${API_BASE}/api/leads`, {
    headers: {
      'Cookie': Astro.request.headers.get('cookie') || '',
    },
  });
  
  if (!res.ok) throw new Error(`API responded ${res.status}`);
  const data = await res.json();
  leads = data.leads;
} catch (e: any) {
  error = e.message;
}
---

<DashboardLayout 
  title="Leads" 
  subtitle="Manage and track incoming business inquiries from Airtable."
  activeRoute="/dashboard/leads"
>
  {error && (
    <div class="dash-error">
      <span class="material-icons-round">error_outline</span>
      Failed to load leads: {error}
    </div>
  )}

  <div class="dash-table-card">
    <div class="dash-table-header">
      <h3>
        <span class="material-icons-round">list_alt</span>
        All Leads ({leads.length})
      </h3>
      
      <div class="dash-search-wrap">
        <span class="material-icons-round">search</span>
        <input type="text" class="dash-search" placeholder="Search by name, email..." id="lead-search" />
      </div>
    </div>

    <div style="overflow-x: auto;">
      <table class="dash-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Status</th>
            <th>Source</th>
            <th>Date Received</th>
          </tr>
        </thead>
        <tbody id="leads-body">
          {leads.length > 0 ? leads.map(lead => (
            <tr>
              <td style="font-weight: 500; color: var(--color-text);">{lead.name || '—'}</td>
              <td>{lead.email || '—'}</td>
              <td>
                <span class={`badge badge-${lead.status?.toLowerCase().replace(/\s+/g, '-') || 'new'}`}>
                  {lead.status || 'New'}
                </span>
              </td>
              <td>{lead.source || 'Website'}</td>
              <td>{new Date(lead.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' })}</td>
            </tr>
          )) : (
            <tr>
              <td colspan="5" style="text-align: center; padding: 3rem 0; color: var(--color-text-dim);">
                <span class="material-icons-round" style="font-size: 2.5rem; opacity: 0.3; display: block; margin-bottom: 0.5rem;">inbox</span>
                No leads found.
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>
</DashboardLayout>

<script>
  // Client-side search filter
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('lead-search') as HTMLInputElement;
    const tbody = document.getElementById('leads-body');
    
    searchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value.toLowerCase();
      const rows = tbody?.querySelectorAll('tr') || [];
      
      rows.forEach(row => {
        // Skip the "No leads found" row if it exists
        if (row.cells.length === 1) return;
        
        const text = row.textContent?.toLowerCase() || '';
        (row as HTMLElement).style.display = text.includes(query) ? '' : 'none';
      });
    });
  });
</script>
